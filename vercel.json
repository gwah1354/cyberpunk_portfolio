{
  "rewrites": [
    {
      "source": "/",
      "destination": "/public/index.html"
    },
    {
      "source": "/login",
      "destination": "/public/auth/login.html"
    },
    {
      "source": "/admin",
      "destination": "/public/admin/admin.html"
    },
    {
      "source": "/(.*)",
      "destination": "/public/index.html"
    }
  ]
}